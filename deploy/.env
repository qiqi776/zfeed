COMPOSE_PROJECT_NAME=zfeed

# App images
FRONT_API_IMAGE=zfeed-front-api:dev
CONTENT_RPC_IMAGE=zfeed-content-rpc:dev
INTERACTION_RPC_IMAGE=zfeed-interaction-rpc:dev
USER_RPC_IMAGE=zfeed-user-rpc:dev
COUNT_RPC_IMAGE=zfeed-count-rpc:dev

# Infra runtime
MYSQL_HOST=mysql
REDIS_HOST=redis
REDIS_PORT=6379
ETCD_HOST=etcd
ETCD_PORT=2379
KAFKA_BROKERS=kafka:9092
MYSQL_APP_PORT=3306
FRONT_API_HOST=0.0.0.0
FRONT_API_PORT=5000
CONTENT_RPC_LISTEN_ON=0.0.0.0:5001
INTERACTION_RPC_LISTEN_ON=0.0.0.0:5002
USER_RPC_LISTEN_ON=0.0.0.0:5003
COUNT_RPC_LISTEN_ON=0.0.0.0:5004
PROM_HOST=0.0.0.0
PROM_PORT=9290
CONTENT_PROM_PORT=9291
COUNT_PROM_PORT=9292
INTERACTION_PROM_PORT=9293
USER_PROM_PORT=9294
LOG_PATH=/var/log/zfeed
PROMETHEUS_HOST_PORT=19090
PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
LOGSTASH_IMAGE=docker.elastic.co/logstash/logstash:8.15.3
FILEBEAT_IMAGE=docker.elastic.co/beats/filebeat:8.15.3
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector:0.100.0
JAEGER_IMAGE=jaegertracing/all-in-one:1.54
OTEL_ENDPOINT=otel-collector:4317
OTEL_HTTP_ENDPOINT=http://otel-collector:4318
OTEL_COLLECTOR_GRPC_HOST_PORT=4317
OTEL_COLLECTOR_HTTP_HOST_PORT=4318
JAEGER_HOST_PORT=16686
ENABLE_TRACE_PIPELINE=0

# Etcd
ETCD_IMAGE=bitnamilegacy/etcd:latest
ETCD_HOST_PORT=12379
ETCD_PEER_PORT=2380
ETCD_PEER_HOST_PORT=12380

# Redis
REDIS_IMAGE=redis:7.2
REDIS_HOST_PORT=16379

# MySQL
MYSQL_IMAGE=mysql:8.0
MYSQL_PORT=33306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=zfeed
MYSQL_USER=zfeed
MYSQL_PASSWORD=123456

# Kafka (KRaft)
KAFKA_IMAGE=bitnamilegacy/kafka:3.5.2
KAFKA_HOST_PORT=19092
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_CLUSTER_ID=pwc-TOq3SkSuLvBA8dxkRQ

# XXL-JOB
XXL_JOB_IMAGE=xuxueli/xxl-job-admin:2.4.1
XXL_JOB_PORT=8081
XXL_JOB_ADMIN_ADDR=http://xxl-job-admin:8080/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token
XXL_JOB_EXECUTOR_PORT=5005
XXL_EXECUTOR_ADDRESS=content-rpc:5005
XXL_EXECUTOR_REGISTRY_ADDRESS=content-rpc:5005
XXL_EXECUTOR_IP=content-rpc
XXL_EXECUTOR_PORT=5005

# Canal
CANAL_IMAGE=canal/canal-server:latest
CANAL_PORT=11111
