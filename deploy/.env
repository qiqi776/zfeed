COMPOSE_PROJECT_NAME=zfeed

# Infra runtime
MYSQL_HOST=mysql
REDIS_HOST=redis
ETCD_HOST=etcd
KAFKA_BROKERS=kafka:9092
MYSQL_APP_PORT=3306
FRONT_API_HOST=0.0.0.0
USER_RPC_LISTEN_ON=0.0.0.0:5003
PROM_HOST=0.0.0.0
LOG_PATH=/var/log/zfeed

# Etcd
ETCD_IMAGE=bitnamilegacy/etcd:latest
ETCD_CLIENT_PORT=2379
ETCD_PEER_PORT=2380

# Redis
REDIS_IMAGE=redis:7.2
REDIS_PORT=6379

# MySQL
MYSQL_IMAGE=mysql:8.0
MYSQL_PORT=33306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=zfeed
MYSQL_USER=zfeed
MYSQL_PASSWORD=123456

# Kafka (KRaft)
KAFKA_IMAGE=bitnamilegacy/kafka:3.5.2
KAFKA_HOST_PORT=19092
KAFKA_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_CLUSTER_ID=pwc-TOq3SkSuLvBA8dxkRQ

# Canal
CANAL_IMAGE=canal/canal-server:latest
CANAL_PORT=11111
