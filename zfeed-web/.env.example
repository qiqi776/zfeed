# Local dev should normally keep VITE_API_BASE_URL unset so the browser can stay
# same-origin and let Vite proxy /v1 requests to the backend below.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:5000

# Optional: set this only when the frontend must call a different API origin
# directly, such as a deployed cross-origin environment.
# VITE_API_BASE_URL=https://api.example.com
